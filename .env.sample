 # --- Bitbucket Server (used by `npm run start:server`, the default entrypoint) ---
BITBUCKET_BASE_URL=https://bitbucket.example.com
BITBUCKET_PAT=your-bitbucket-personal-access-token
# Bot account username (defaults to "carrot" if unset)
BITBUCKET_BOT_USERNAME=carrot

# Bitbucket Cloud (alternative provider — used by `npm run start:cloud`)
# Set BITBUCKET_CLOUD_BOT_EMAIL only when using an Atlassian API token (Basic auth);
# leave it empty when using a Workspace/Repo Access Token (Bearer auth, Premium-only).
BITBUCKET_CLOUD_WORKSPACE=
BITBUCKET_CLOUD_ACCESS_TOKEN=
BITBUCKET_CLOUD_BOT_USERNAME=
BITBUCKET_CLOUD_BOT_EMAIL=

# Audit monitoring works via Bitbucket build-status API — no Bamboo credentials needed.

# --- Docker (optional) ---
# Override the base image / published image name for `docker compose build`.
# Defaults build against the public node image (docker.io/library/node:24).
# from_registry=docker.io
# from_repository=library/node
# from_tag=24
# image=local-git-reviewer

# Up to four review/validation models. Each NAME must be UNIQUE — a model never
# validates findings it authored, and the footer aggregates token usage by NAME,
# so duplicate names break self-exclusion and merge cost rows.
# --- Model 1 (always a validator; set MODEL1_REVIEW=true to also run the review pass) ---
MODEL1_NAME=Model1
MODEL1_API_KEY=
MODEL1_API_BASE=
MODEL1_MODEL=
MODEL1_AUTH_HEADER=
MODEL1_SUPPORTS_STRUCTURED_OUTPUT=true
MODEL1_MAX_TOKEN_PARAM=max_completion_tokens
MODEL1_INPUT_COST=0
MODEL1_OUTPUT_COST=0
MODEL1_REVIEW=false
# Review personas for this model — comma-separated, only used when MODEL1_REVIEW=true.
# The model runs the review pass ONCE PER ROLE, each with a role-focused prompt, so
# two roles = two pi-runs for this model. Allowed roles:
#   correctness | security | readability | generic   (generic = all-round review)
# Default: generic. At least one review model must cover correctness (or generic),
# or the bot refuses to start. Unknown or duplicate roles also fail at startup.
# Example — run this model as two focused reviewers:
#   MODEL1_ROLES=security,correctness
MODEL1_ROLES=generic
# Required only when MODEL1_REVIEW=true (Docker pi-runner review pass).
# Must match the model. Supported: anthropic | google | openai |
# azure-openai-responses | openrouter | xai | deepseek | mistral | groq.
# The key above is forwarded to pi under that provider's env var
# (anthropic->ANTHROPIC_API_KEY, google->GEMINI_API_KEY, ...). Only
# azure-openai-responses reads MODEL1_API_BASE; other providers use pi's
# built-in base, so set MODEL1_API_BASE to the OpenAI-compatible /chat/completions
# URL for the validator path (see README "Endpoint compatibility").
#   Anthropic: MODEL1_API_BASE=https://api.anthropic.com/v1/  + MODEL1_PROVIDER=anthropic
#   Gemini:    MODEL1_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai  + MODEL1_PROVIDER=google
MODEL1_PROVIDER=azure-openai-responses
MODEL1_DOCKER_IMAGE=lgr-pi-runner:latest
MODEL1_TIMEOUT_MS=300000

# --- Model 2 (always a validator; set MODEL2_REVIEW=true to also run the review pass) ---
MODEL2_NAME=Model2
MODEL2_API_KEY=
MODEL2_API_BASE=
MODEL2_MODEL=
MODEL2_AUTH_HEADER=
MODEL2_SUPPORTS_STRUCTURED_OUTPUT=true
MODEL2_MAX_TOKEN_PARAM=max_completion_tokens
MODEL2_INPUT_COST=0
MODEL2_OUTPUT_COST=0
MODEL2_REVIEW=false
# Review personas (see Model 1). Default: generic.
MODEL2_ROLES=generic
# Required only when MODEL2_REVIEW=true — see Model 1 above for provider options:
MODEL2_PROVIDER=azure-openai-responses
MODEL2_DOCKER_IMAGE=lgr-pi-runner:latest
MODEL2_TIMEOUT_MS=300000

# --- Model 3 (always a validator; set MODEL3_REVIEW=true to also run the review pass) ---
MODEL3_NAME=Model3
MODEL3_API_KEY=
MODEL3_API_BASE=
MODEL3_MODEL=
MODEL3_AUTH_HEADER=
MODEL3_SUPPORTS_STRUCTURED_OUTPUT=true
MODEL3_MAX_TOKEN_PARAM=max_completion_tokens
MODEL3_INPUT_COST=0
MODEL3_OUTPUT_COST=0
MODEL3_REVIEW=false
# Review personas (see Model 1). Default: generic.
MODEL3_ROLES=generic
# Required only when MODEL3_REVIEW=true — see Model 1 above for provider options:
MODEL3_PROVIDER=azure-openai-responses
MODEL3_DOCKER_IMAGE=lgr-pi-runner:latest
MODEL3_TIMEOUT_MS=300000

# --- Model 4 (always a validator; set MODEL4_REVIEW=true to also run the review pass) ---
MODEL4_NAME=Model4
MODEL4_API_KEY=
MODEL4_API_BASE=
MODEL4_MODEL=
MODEL4_AUTH_HEADER=
MODEL4_SUPPORTS_STRUCTURED_OUTPUT=true
MODEL4_MAX_TOKEN_PARAM=max_completion_tokens
MODEL4_INPUT_COST=0
MODEL4_OUTPUT_COST=0
MODEL4_REVIEW=false
# Review personas (see Model 1). Default: generic.
MODEL4_ROLES=generic
# Required only when MODEL4_REVIEW=true — see Model 1 above for provider options:
MODEL4_PROVIDER=azure-openai-responses
MODEL4_DOCKER_IMAGE=lgr-pi-runner:latest
MODEL4_TIMEOUT_MS=300000

# --- Shared review settings ---
REVIEW_MAX_DIFF_LINES=5000
REVIEW_MAX_FILE_LINES=1000
# Token cap for the info-gatherer LLM that fetches extra files/symbols
# (e.g. DTO definitions referenced by the diff) to enrich validator context.
# The FIRST validator-enabled model (Model1 by default) is used as the
# info-gatherer — re-order your models if you want a different one in
# this role. Set to 0 to disable info-gathering entirely.
REVIEW_MAX_INFO_TOKENS=8000
# Every review-enabled model runs on each PR (once per assigned role). Validators,
# however, are capped: if more validator-enabled models are configured than this,
# a random subset of this size votes per PR (set to 0 for no cap).
REVIEW_MAX_VALIDATORS=2

# Summarizer model for changelog summaries in audit fix PRs (OpenAI-compatible, required)
# Can be the same model as a validator — a cheap/fast model is recommended.
SUMMARIZER_API_KEY=
SUMMARIZER_API_BASE=https://api.openai.com/v1
SUMMARIZER_MODEL=gpt-14-mini
SUMMARIZER_NAME=Summarizer
SUMMARIZER_INPUT_COST=0.15
SUMMARIZER_OUTPUT_COST=0.60

NODE_ENV=development
